# ====================================
# PremiumBrain.ai — Environment Variables
# ====================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Admin Panel Password (required for /admin access)
ADMIN_PASSWORD=your-secure-password-here

# Optional: Make admin password available client-side (for login form)
# If not set, falls back to ADMIN_PASSWORD via API
NEXT_PUBLIC_ADMIN_PASSWORD=

# ── Analytics & Tracking (optional) ──
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=

# ── External Links (optional) ──
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/premiumbrain/demo
NEXT_PUBLIC_COMMUNITY_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# ── Vercel-specific (auto-set by Vercel) ──
# VERCEL_URL=
# VERCEL_ENV=
